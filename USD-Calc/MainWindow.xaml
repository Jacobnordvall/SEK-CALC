<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="USD_Calc.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:USD_Calc"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SEK CALC">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar area: extend content into title bar and use same background -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="36" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Large drag area spans the full row; OwnerText is placed afterward so it sits above DragArea and remains clickable -->
            <!-- Drag area contains only the app icon so header remains draggable -->
            <Border x:Name="DragArea" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="8,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/dollar-sign.png" Width="18" Height="18" Stretch="Uniform" Margin="4,0,6,0" />
                </StackPanel>
            </Border>
            <!-- Global copy confirmation overlay removed from title; will be shown below the result -->
        </Grid>

        <!-- Settings panel (in-window, hidden by default). Start at the same row as the main content so it doesn't overlap the title bar. -->
        <Grid x:Name="SettingsPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="1" Grid.RowSpan="2" Canvas.ZIndex="5">
            <!-- Full-window overlay background dimmer -->
            <Rectangle Fill="#80000000" Grid.ColumnSpan="2" />

            <!-- Left docked settings column (flat, no outline) -->
            <Grid Width="280" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="12" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

                    <TextBlock Text="Multiplier" Margin="0,6,0,4" />
                    <TextBox x:Name="SettingsMultiplierBox" Width="160" HorizontalAlignment="Left" />

                    <!-- Checkbox on the left for consistent layout -->
                    <CheckBox x:Name="SettingsRoundUpCheck" Content="Always round up" IsChecked="True" Margin="0,6,0,0" />

                    <CheckBox x:Name="SettingsAlwaysOnTopCheck" Content="Always on top" Margin="0,12,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0" Spacing="8">
                    <Button x:Name="SettingsSaveButton" Content="Save" Click="OnSettingsSaveClicked" />
                    <Button x:Name="SettingsCloseButton" Content="Close" Click="OnSettingsCloseClicked" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Always-on-top toggle removed from bottom-left; placed next to hint/owner text below -->

        <Grid Grid.Row="1" Margin="12" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="USD:" VerticalAlignment="Center" Margin="0,0,8,0" x:Name="UsdLabel" Grid.Column="0" />
            <TextBox x:Name="InputBox" Width="240" PlaceholderText="e.g. 5" TextChanged="OnInputChanged" KeyDown="OnInputKeyDown" HorizontalAlignment="Left" Grid.Column="1" />
        </Grid>

        <Grid Grid.Row="2" Padding="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border x:Name="ResultBorder" Background="Transparent" CornerRadius="6" Padding="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Row="0" MinHeight="160" PointerPressed="ResultBorder_PointerPressed">
                <Border.RenderTransform>
                    <TranslateTransform Y="-20" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Viewbox ensures the SEK text scales to available space and won't be clipped -->
                    <Viewbox Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="0" MaxHeight="9999">
                        <TextBlock x:Name="ResultText" Text="" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Tapped="ResultText_Tapped" />
                    </Viewbox>

                    <!-- Copy confirmation shown below the result -->
                    <Border x:Name="GlobalCopiedBorder" Grid.Row="1" Background="#DD000000" CornerRadius="6" Padding="8" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0">
                        <TextBlock x:Name="GlobalCopiedText" Text="Copied!" Foreground="White" FontWeight="SemiBold" />
                        <Border.RenderTransform>
                            <TranslateTransform Y="-8" />
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Toggle on the left column: show a clear label next to the switch instead of On/Off text -->
                <!-- compact On/Off toggle restored as before -->
                <!-- Left: Owner -->
                <Border Grid.Column="0" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock x:Name="OwnerText" Text="Jacob Norrdvall" FontWeight="SemiBold" Foreground="CornflowerBlue" TextDecorations="Underline" Tapped="OnNameTapped" FontSize="16" />
                </Border>
                <!-- Middle: hint (removed per user request) -->
                <TextBlock x:Name="HintText" Grid.Column="1" Text="" Opacity="0.0" VerticalAlignment="Center" HorizontalAlignment="Center" />
                <!-- Right: Settings button -->
                <Border Grid.Column="2" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                <Button x:Name="SettingsButton" Click="OnSettingsClicked" Width="36" Height="36" HorizontalAlignment="Right" Background="Transparent" BorderBrush="Transparent" Padding="4" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0">
                        <!-- Increased button and image size for better tap target -->
                        <Image Source="ms-appx:///Assets/settingsICONmine.png" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Border>
            </Grid>
        </Grid>


    </Grid>
</Window>
